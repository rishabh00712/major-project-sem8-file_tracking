<%- include("partials/header", { docker_search: true }) %>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .search-wrapper {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    background: #eae6de;
    padding: 48px 20px 20px;
  }

  .search-card {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.08);
    padding: 48px 40px;
    width: 100%;
    max-width: 460px;
  }

  .search-icon {
    font-size: 36px;
    text-align: center;
    margin-bottom: 12px;
  }

  .search-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 700;
    color: #1a2332;
    text-align: center;
    margin-bottom: 6px;
  }

  .search-sub {
    font-size: 13px;
    color: #8a9aaa;
    text-align: center;
    margin-bottom: 32px;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 20px;
  }

  .field-group label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5a6a7a;
  }

  .field-group input {
    padding: 12px 16px;
    border: 1.5px solid #ddd8ce;
    border-radius: 10px;
    font-size: 14px;
    background: #faf9f7;
    outline: none;
  }

  .field-group input.error {
    border-color: #e05252;
  }

  .error-msg {
    font-size: 11px;
    color: #e05252;
    display: none;
  }
  .error-msg.show { display: block; }

  .btn-submit {
    width: 100%;
    padding: 13px;
    background: #1a2332;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    cursor: pointer;
  }

  .server-error {
    background: #fff0f0;
    border: 1px solid #f5c6c6;
    color: #c0392b;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 12px;
    margin-bottom: 20px;
    text-align: center;
    display: none;
  }
  .server-error.show { display: block; }

  /* ── LOADING OVERLAY ── */
  #loadingOverlay {
    display: none;
    position: fixed;
    inset: 0;
    background: #eae6de;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }
  #loadingOverlay.show {
    display: flex;
  }

  .lo-card {
    background: #fff;
    border-radius: 2px;
    padding: 56px 44px;
    width: 100%;
    max-width: 420px;
    margin: 16px;
    box-shadow: 0 4px 32px rgba(6,23,46,0.08);
    animation: formSlideUp 0.4s cubic-bezier(.4,0,.2,1) both;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }

  .lo-icon {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #d4a843, #b8922a);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
  }

  .lo-title { text-align: center; }
  .lo-title h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 700;
    color: #06172e;
    letter-spacing: 0.02em;
    margin-bottom: 6px;
  }
  .lo-title p {
    font-size: 12px;
    color: #8a9aaa;
    letter-spacing: 0.03em;
  }

  .lo-track {
    width: 100%;
    height: 3px;
    background: #ede8df;
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }

  .lo-bar {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    width: 30%;
    background: linear-gradient(90deg, #b8922a, #f0c84a, #d4a843);
    border-radius: 2px;
    animation: barFlow 1.6s ease-in-out infinite;
  }

  .lo-dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .lo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #d4a843;
    animation: dotBounce 1.2s ease-in-out infinite;
  }
  .lo-dot:nth-child(1) { animation-delay: 0s; }
  .lo-dot:nth-child(2) { animation-delay: 0.2s; }
  .lo-dot:nth-child(3) { animation-delay: 0.4s; }

  .lo-status {
    font-size: 12px;
    color: #8a9aaa;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    animation: pulse 2s ease-in-out infinite;
  }

  .lo-divider {
    width: 100%;
    height: 1px;
    background: #ede8df;
  }

  .lo-footer {
    font-size: 11px;
    color: #b0bac5;
    text-align: center;
    line-height: 1.6;
  }

  /* ── EASY LOADING (PAGE LOAD) ── */
  #easyLoader {
    display: flex;
  }

  .skeleton {
    background: linear-gradient(90deg, #eee, #ddd, #eee);
    background-size: 200px 100%;
    animation: shimmer 1.2s infinite;
    border-radius: 8px;
  }

  @keyframes shimmer {
    0% { background-position: -200px 0; }
    100% { background-position: 200px 0; }
  }

  @keyframes barFlow {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(300%); }
  }

  @keyframes dotBounce {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @media (max-width: 480px) {
    .search-card {
      padding: 32px 20px;
      border-radius: 12px;
    }
    .search-title { font-size: 22px; }
  }
</style>

<!-- ── EASY LOADING (PAGE LOAD) ── -->
<div id="easyLoader" class="search-wrapper">
  <div class="search-card">
    <div class="skeleton" style="width:36px;height:36px;margin:0 auto 12px;"></div>
    <div class="skeleton" style="width:220px;height:24px;margin:0 auto 8px;"></div>
    <div class="skeleton" style="width:260px;height:14px;margin:0 auto 30px;"></div>

    <div class="field-group">
      <div class="skeleton" style="width:120px;height:12px;"></div>
      <div class="skeleton" style="width:100%;height:42px;"></div>
    </div>

    <div class="skeleton" style="width:100%;height:44px;margin-top:10px;"></div>
  </div>
</div>

<!-- REAL CONTENT -->
<div id="content" style="display:none;">
  <div class="search-wrapper">
    <div class="search-card">

      <div class="search-icon">📂</div>
      <div class="search-title">File Flow Viewer</div>
      <div class="search-sub">Enter a docket number to view its file flow records</div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="server-error show">⚠ <%= error %></div>
      <% } %>

      <form action="/view_flow" method="POST" onsubmit="return handleSubmit()">
        <div class="field-group">
          <label>Docket Number</label>
          <input
            type="text"
            name="docket"
            id="docketInput"
            placeholder="e.g. R123"
            autocomplete="off"
            autofocus
          >
          <span class="error-msg" id="docketError">Please enter a docket number.</span>
        </div>

        <button type="submit" class="btn-submit">View File Flow →</button>
      </form>

    </div>
  </div>
</div>

<!-- ── LOADING OVERLAY ── -->
<div id="loadingOverlay">
  <div class="lo-card">
    <div class="lo-icon">🔑</div>
    <div class="lo-title">
      <h1>Verifying Docker Number</h1>
      <p>Please wait while we verify your docker number</p>
    </div>
    <div class="lo-track">
      <div class="lo-bar"></div>
    </div>
    <div class="lo-dots">
      <div class="lo-dot"></div>
      <div class="lo-dot"></div>
      <div class="lo-dot"></div>
    </div>
    <div class="lo-status">Verifying...</div>
    <div class="lo-divider"></div>
    <div class="lo-footer">
      Research and Consultancy Cell<br>
      Indian Institute of Engineering Science and Technology, Shibpur
    </div>
  </div>
</div>

<%- include("partials/footer") %>

<script>
  function handleSubmit() {
    const input = document.getElementById('docketInput');
    const errMsg = document.getElementById('docketError');

    if (!input.value.trim()) {
      input.classList.add('error');
      errMsg.classList.add('show');
      input.focus();
      return false;
    }

    document.getElementById('loadingOverlay').classList.add('show');
    document.querySelector('.btn-submit').disabled = true;

    return true;
  }

  document.getElementById('docketInput').addEventListener('input', function() {
    this.classList.remove('error');
    document.getElementById('docketError').classList.remove('show');
  });

  window.addEventListener("load", () => {
    setTimeout(() => {
      document.getElementById("easyLoader").style.display = "none";
      document.getElementById("content").style.display = "block";
    }, 600);
  });
</script>