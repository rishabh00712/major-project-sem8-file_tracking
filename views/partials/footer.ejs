<footer style="background:#f5f0e8; font-family:'DM Sans',sans-serif; position:relative; overflow:hidden; margin-top:auto;">

  <!-- grid overlay -->
  <div style="position:absolute; inset:0; background-image:linear-gradient(rgba(184,146,42,0.06) 1px,transparent 1px),linear-gradient(90deg,rgba(184,146,42,0.06) 1px,transparent 1px); background-size:40px 40px; pointer-events:none;"></div>

  <!-- top rule -->
  <div style="height:1px; background:linear-gradient(90deg,transparent,rgba(184,146,42,0.4),transparent);"></div>

  <!-- footer main -->
  <div style="max-width:1000px; margin:0 auto; padding:36px 36px 24px; position:relative; z-index:1;">

    <!-- top section: 3 columns -->
    <div style="display:flex; flex-wrap:wrap; gap:32px; justify-content:space-between; margin-bottom:28px;">

      <!-- Col 1: Institute -->
      <div style="flex:1; min-width:200px; display:flex; flex-direction:column; gap:8px;">
        <span style="font-size:10px; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:#b8922a;">Institution</span>
        <span style="font-family:'Cormorant Garamond',serif; font-size:16px; font-weight:700; color:#1a2332; line-height:1.3;">Indian Institute of Engineering Science and Technology, Shibpur</span>
        <span style="font-size:12px; color:#5a6a7a; line-height:1.6;">Botanic Garden, Howrah,<br>West Bengal — 711 103</span>
      </div>

        <!-- Col 2: Quick Links -->
        <% if (!locals._isViewer) { %>
          <div style="flex:1; min-width:160px; display:flex; flex-direction:column; gap:8px;">
            <span style="font-size:10px; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:#b8922a;">Quick Links</span>
            <a href="/file_add" style="font-size:13px; color:#1a2332; text-decoration:none; padding:3px 0; border-bottom:1px solid transparent; transition:color 0.2s;"
              onmouseover="this.style.color='#b8922a';" onmouseout="this.style.color='#1a2332';">File Entry</a>
            <a href="/file_search" style="font-size:13px; color:#1a2332; text-decoration:none; padding:3px 0;"
              onmouseover="this.style.color='#b8922a';" onmouseout="this.style.color='#1a2332';">File Search</a>
            <a href="/view_flow" style="font-size:13px; color:#1a2332; text-decoration:none; padding:3px 0;"
              onmouseover="this.style.color='#b8922a';" onmouseout="this.style.color='#1a2332';">Track File</a>
          </div>
        <%}%>
        
      <!-- Col 3: Contact -->
      <div style="flex:1; min-width:180px; display:flex; flex-direction:column; gap:8px;">
        <span style="font-size:10px; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:#b8922a;">Contact</span>
        <span style="font-size:13px; color:#5a6a7a; line-height:1.7;">
          R&amp;C Cell Office<br>
          IIEST Shibpur<br>
          📞 +91-33-2668-4561<br>
          ✉️ randc@iiest.ac.in
        </span>
      </div>

      <!-- Col 4: Developer -->
      <div style="flex:1; min-width:160px; display:flex; flex-direction:column; gap:8px; align-items:flex-end;">
        <span style="font-size:10px; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:#b8922a;">Developed By</span>
        <span style="font-size:14px; font-weight:700; color:#1a2332; letter-spacing:0.02em;">Rishabh Garai</span>
        <span style="font-size:11px; color:#8a9aaa;">B.Tech, IIEST Shibpur</span>
        <span style="font-size:11px; color:#8a9aaa;">© 2026 All rights reserved</span>
      </div>

    </div>

    <!-- divider -->
    <div style="height:1px; background:linear-gradient(90deg,transparent,rgba(184,146,42,0.3),transparent); margin-bottom:18px;"></div>

    <!-- bottom bar -->
    <div style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:8px;">
      <span style="font-size:11px; color:#8a9aaa; letter-spacing:0.04em;">
        Research and Development Cell &nbsp;·&nbsp; IIEST Shibpur &nbsp;·&nbsp; Est. 1856
      </span>
      <span style="font-size:11px; color:#b8922a; font-weight:600; letter-spacing:0.06em;">
        File Tracking System v1.0
      </span>
    </div>

  </div>

  <!-- bottom gold bar -->
  <div style="height:3px; background:linear-gradient(90deg,#b8922a,#f0c84a,#d4a843,#b8922a); background-size:400px 100%;"></div>

</footer>

<style>
  @media (max-width: 600px) {
    footer > div:nth-child(3) > div:first-child {
      flex-direction: column !important;
      gap: 24px !important;
      padding: 28px 20px 16px !important;
    }
    footer > div:nth-child(3) > div:first-child > div:last-child {
      align-items: flex-start !important;
    }
  }
</style>