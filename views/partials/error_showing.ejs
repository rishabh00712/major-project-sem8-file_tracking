<style>
  @keyframes errorSlideIn {
    from { opacity: 0; transform: translateY(-16px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes errorSlideOut {
    from { opacity: 1; transform: translateY(0) scale(1); }
    to   { opacity: 0; transform: translateY(-16px) scale(0.97); }
  }
  @keyframes errorProgress {
    from { width: 100%; }
    to   { width: 0%; }
  }

  .error-toast-wrap {
    position: fixed;
    top: 100px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 99999;
    width: 100%;
    max-width: 480px;
    padding: 0 16px;
    pointer-events: none;
  }

  .error-toast {
    background: #ffffff;
    border-left: 4px solid #c0392b;
    border-radius: 2px;
    box-shadow: 0 8px 32px rgba(6,23,46,0.14), 0 2px 8px rgba(192,57,43,0.12);
    padding: 16px 18px 14px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    pointer-events: all;
    animation: errorSlideIn 0.4s cubic-bezier(.4,0,.2,1) both;
    position: relative;
    overflow: hidden;
  }

  .error-toast.hiding {
    animation: errorSlideOut 0.4s cubic-bezier(.4,0,.2,1) both;
  }

  .error-toast-icon {
    width: 32px;
    height: 32px;
    background: rgba(192,57,43,0.10);
    border: 1px solid rgba(192,57,43,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .error-toast-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .error-toast-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-weight: 700;
    color: #06172e;
    letter-spacing: 0.01em;
  }

  .error-toast-msg {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    color: #5a6a7a;
    line-height: 1.6;
  }

  .error-toast-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px 4px;
    font-size: 16px;
    color: #b0bbc6;
    line-height: 1;
    flex-shrink: 0;
    transition: color 0.2s;
    font-family: 'DM Sans', sans-serif;
  }
  .error-toast-close:hover { color: #c0392b; }

  /* Progress bar at bottom */
  .error-toast-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    background: linear-gradient(90deg, #c0392b, #e74c3c);
    animation: errorProgress 5s linear forwards;
    border-radius: 0 0 0 2px;
  }

  @media (max-width: 480px) {
    .error-toast-wrap { top: 80px; }
    .error-toast-title { font-size: 14px; }
    .error-toast-msg { font-size: 11px; }
  }
</style>

<% if (typeof error !== 'undefined' && error) { %>
<div class="error-toast-wrap" id="errorToastWrap">
  <div class="error-toast" id="errorToast">

    <div class="error-toast-icon">⚠</div>

    <div class="error-toast-body">
      <div class="error-toast-title">Something went wrong</div>
      <div class="error-toast-msg"><%= error %></div>
    </div>

    <button class="error-toast-close" onclick="dismissError()" title="Dismiss">✕</button>

    <div class="error-toast-bar" id="errorBar"></div>

  </div>
</div>

<script>
  (function () {
    var wrap    = document.getElementById('errorToastWrap');
    var toast   = document.getElementById('errorToast');
    var timer   = null;

    function dismissError() {
      clearTimeout(timer);
      toast.classList.add('hiding');
      toast.addEventListener('animationend', function () {
        if (wrap) wrap.remove();
      }, { once: true });
    }

    // Auto dismiss after 5s
    timer = setTimeout(dismissError, 5000);

    // Expose globally so close button can call it
    window.dismissError = dismissError;
  })();
</script>
<% } %>