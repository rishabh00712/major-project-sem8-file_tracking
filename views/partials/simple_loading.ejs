<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loading...</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #eae6de;
      font-family: 'DM Sans', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    @keyframes barFlow {
      0%   { transform: translateX(-100%); }
      100% { transform: translateX(400%); }
    }

    @keyframes dotBounce {
      0%, 80%, 100% { transform: translateY(0); opacity: 0.4; }
      40%           { transform: translateY(-8px); opacity: 1; }
    }

    .card {
      background: #fff;
      border-radius: 2px;
      padding: 56px 44px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 4px 32px rgba(6,23,46,0.08);
      animation: fadeIn 0.5s cubic-bezier(.4,0,.2,1) both;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 28px;
    }

    @media (max-width: 480px) {
      .card { padding: 40px 20px; margin: 16px; }
    }

    /* ── Icon ── */
    .loading-icon {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, #d4a843, #b8922a);
      border-radius: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
    }

    /* ── Title block ── */
    .title-block {
      text-align: center;
    }

    .title-block h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 700;
      color: #06172e;
      letter-spacing: 0.02em;
      margin-bottom: 6px;
    }

    .title-block p {
      font-size: 12px;
      color: #8a9aaa;
      letter-spacing: 0.03em;
    }

    /* ── Progress bar ── */
    .progress-track {
      width: 100%;
      height: 3px;
      background: #ede8df;
      border-radius: 2px;
      overflow: hidden;
      position: relative;
    }

    .progress-bar {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 30%;
      background: linear-gradient(90deg, #b8922a, #f0c84a, #d4a843);
      border-radius: 2px;
      animation: barFlow 1.6s ease-in-out infinite;
    }

    /* ── Dots ── */
    .dots {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #d4a843;
      animation: dotBounce 1.2s ease-in-out infinite;
    }

    .dot:nth-child(1) { animation-delay: 0s; }
    .dot:nth-child(2) { animation-delay: 0.2s; }
    .dot:nth-child(3) { animation-delay: 0.4s; }

    /* ── Status text ── */
    .status-text {
      font-size: 12px;
      color: #8a9aaa;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      animation: pulse 2s ease-in-out infinite;
    }

    /* ── Divider ── */
    .divider {
      width: 100%;
      height: 1px;
      background: #ede8df;
    }

    /* ── Footer note ── */
    .footer-note {
      font-size: 11px;
      color: #b0bac5;
      text-align: center;
      line-height: 1.6;
    }

  </style>
</head>
<body>

<div class="card">

  <div class="loading-icon">⏳</div>

  <div class="title-block">
    <h1>Please Wait</h1>
    <p>Your request is being processed</p>
  </div>

  <div class="progress-track">
    <div class="progress-bar"></div>
  </div>

  <div class="dots">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>

  <div class="status-text">Loading...</div>

  <div class="divider"></div>

  <div class="footer-note">
    Research and Consultancy Cell<br>
    Indian Institute of Engineering Science and Technology, Shibpur
  </div>

</div>

</body>
</html>